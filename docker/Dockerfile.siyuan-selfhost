# SiYuan self-host kernel image.
#
# Built from the stripped kernel + stripped frontend produced by the Part A surgery. This
# is functionally equivalent to the upstream b3log/siyuan image with every outbound
# integration removed: no bazaar, no b3log cloud sync, no account service, no update
# checker. See ~/.claude/plans/fuzzy-booping-rocket.md for the full rationale.
#
# Build context MUST be the repo root so the frontend and kernel trees are both reachable:
#
#   docker build -f docker/Dockerfile.siyuan-selfhost -t siyuan-selfhost:latest .
#
# This image is identical in shape to the upstream Dockerfile so existing orchestration
# (PUID/PGID, /opt/siyuan layout, entrypoint) keeps working.

# --- 1. Frontend build ---------------------------------------------------------------------
FROM --platform=$BUILDPLATFORM node:21 AS node-build

ARG NPM_REGISTRY=

WORKDIR /app
ADD app/package.json app/pnpm* app/.npmrc .

RUN <<EORUN
#!/bin/bash -e
corepack enable
corepack install --global $(node -e 'console.log(require("./package.json").packageManager)')
npm config set registry ${NPM_REGISTRY}
pnpm install --silent
EORUN

ADD app/ .
RUN <<EORUN
#!/bin/bash -e
pnpm run build
mkdir /artifacts
mv appearance stage guide changelogs /artifacts/
EORUN

# --- 2. Kernel build (self-host variant) ---------------------------------------------------
FROM golang:1.25-alpine AS go-build

RUN <<EORUN
#!/bin/sh -e
apk add --no-cache gcc musl-dev
go env -w GO111MODULE=on
go env -w CGO_ENABLED=1
EORUN

WORKDIR /kernel
ADD kernel/go.* .
RUN --mount=type=cache,target=/root/.cache/go-build --mount=type=cache,target=/go/pkg \
    go mod download

ADD kernel/ .
RUN --mount=type=cache,target=/root/.cache/go-build --mount=type=cache,target=/go/pkg \
    go build -tags fts5 -v -ldflags "-s -w" -o kernel

# --- 3. Runtime ----------------------------------------------------------------------------
FROM alpine:latest
LABEL org.opencontainers.image.source="https://github.com/siyuan-note/siyuan"
LABEL org.opencontainers.image.description="SiYuan self-host multi-user kernel (stripped, no external services)"

RUN apk add --no-cache ca-certificates tzdata su-exec

ENV TZ=UTC
ENV HOME=/home/siyuan
ENV RUN_IN_CONTAINER=true

# Kernel port. The portal reaches this over the siyuan-net internal docker network and
# injects a per-user Authorization: Token header on every request.
EXPOSE 6806

WORKDIR /opt/siyuan/
COPY --from=go-build --chmod=755 /kernel/kernel /kernel/entrypoint.sh .
COPY --from=node-build /artifacts .

# Entry-point preserved from upstream: handles PUID/PGID remapping and exec's the kernel.
ENTRYPOINT ["/opt/siyuan/entrypoint.sh"]
CMD ["/opt/siyuan/kernel"]
